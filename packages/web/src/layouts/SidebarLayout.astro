---
import Layout from './Layout.astro';
import { SidebarLayout } from '@/components/sidebar';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
---

<Layout title={title}>
  <SidebarLayout pathname={pathname} client:load>
    <slot />
  </SidebarLayout>
</Layout>
