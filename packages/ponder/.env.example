# Ponder Database Configuration
# =============================
# This should point to the local Supabase PostgreSQL database
# configured in packages/supabase-ponder

# Supabase PostgreSQL database (run `pnpm db:start` first)
PONDER_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres

# RPC URLs for blockchain data
# Replace with your actual RPC endpoints (Alchemy, Infura, etc.)
PONDER_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
PONDER_RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
PONDER_RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
PONDER_RPC_URL_UNICHAIN=https://unichain-mainnet.g.alchemy.com/v2/YOUR_API_KEY
